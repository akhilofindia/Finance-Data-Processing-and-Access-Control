PORT=5000
JWT_SECRET=your-long-random-secret

# MongoDB Atlas: Database → Connect → Drivers → copy SRV string.
# That database holds collections: users, records (financial data).
# Replace <db_username> and <db_password>; add database name before ? e.g. /finidash
# Password special chars must be URL-encoded (e.g. @ → %40)
MONGODB_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@cluster0.yzlfocv.mongodb.net/finidash?retryWrites=true&w=majority&appName=Cluster0
